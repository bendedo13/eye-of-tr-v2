{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/[locale]/layout,_N_T_/[locale]/visual-location/layout,_N_T_/[locale]/visual-location/page,_N_T_/tr/visual-location"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/$d$locale/visual-location/__PAGE__",
    "/$d$locale/visual-location",
    "/$d$locale",
    "/_index",
    "/_head"
  ]
}