{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/[locale]/layout,_N_T_/[locale]/verify-email/layout,_N_T_/[locale]/verify-email/page,_N_T_/tr/verify-email"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/$d$locale/verify-email/__PAGE__",
    "/$d$locale/verify-email",
    "/$d$locale",
    "/_index",
    "/_head"
  ]
}