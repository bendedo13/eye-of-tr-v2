{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/[locale]/layout,_N_T_/[locale]/data-platform/layout,_N_T_/[locale]/data-platform/page,_N_T_/tr/data-platform"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/$d$locale/data-platform/__PAGE__",
    "/$d$locale/data-platform",
    "/$d$locale",
    "/_index",
    "/_head"
  ]
}