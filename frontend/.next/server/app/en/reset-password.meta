{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/[locale]/layout,_N_T_/[locale]/reset-password/layout,_N_T_/[locale]/reset-password/page,_N_T_/en/reset-password"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/$d$locale/reset-password/__PAGE__",
    "/$d$locale/reset-password",
    "/$d$locale",
    "/_index",
    "/_head"
  ]
}