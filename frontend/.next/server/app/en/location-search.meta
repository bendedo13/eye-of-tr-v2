{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/[locale]/layout,_N_T_/[locale]/location-search/layout,_N_T_/[locale]/location-search/page,_N_T_/en/location-search"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/$d$locale/location-search/__PAGE__",
    "/$d$locale/location-search",
    "/$d$locale",
    "/_index",
    "/_head"
  ]
}