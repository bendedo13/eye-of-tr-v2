{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/[locale]/layout,_N_T_/[locale]/api/layout,_N_T_/[locale]/api/page,_N_T_/en/api"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/$d$locale/api/__PAGE__",
    "/$d$locale/api",
    "/$d$locale",
    "/_index",
    "/_head"
  ]
}