{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/[locale]/layout,_N_T_/[locale]/legal/layout,_N_T_/[locale]/legal/kvkk/layout,_N_T_/[locale]/legal/kvkk/page,_N_T_/en/legal/kvkk"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/$d$locale/legal/kvkk/__PAGE__",
    "/$d$locale/legal/kvkk",
    "/$d$locale/legal",
    "/$d$locale",
    "/_index",
    "/_head"
  ]
}