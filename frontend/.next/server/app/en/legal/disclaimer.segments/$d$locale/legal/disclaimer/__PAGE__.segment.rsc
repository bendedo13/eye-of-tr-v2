0:{"buildId":"ysAYpOQkGJVQXQv-yD-1T","rsc":["$","$1","c",{"children":[["$","$L2",null,{"children":["$","$L3",null,{"locale":"en","slug":"disclaimer","fallbackTitle":"DISCLAIMER","fallbackSubtitle":"Last Updated: February 3, 2026","fallbackContent":["$","div",null,{"className":"space-y-10 font-sans","children":[["$","section",null,{"children":[["$","h1",null,{"children":"Disclaimer: Facial Recognition Search Limitations"}],["$","p",null,{"className":"text-zinc-400 text-xs font-black uppercase tracking-widest mb-6","children":"Last Updated: February 3, 2026"}],["$","p",null,{"children":"FaceSeek is an advanced facial search engine and image intelligence platform designed to assist professionals with OSINT research and identification tasks. However, it is critical that users understand the limitations, risks, and proper use of facial recognition technology before relying on search results."}]]}],["$","section",null,{"className":"space-y-4","children":[["$","h2",null,{"className":"text-xl font-black","children":"1. AI FACIAL RECOGNITION ACCURACY LIMITATIONS"}],["$","p",null,{"children":"While FaceSeek employs state-of-the-art AI facial recognition algorithms, no facial search engine can guarantee 100% accuracy. Users must understand:"}],["$","ul",null,{"className":"list-disc pl-6 space-y-2 text-zinc-500","children":[["$","li",null,{"children":[["$","strong",null,{"children":"False Positives:"}]," Our facial search may return matches that appear visually similar but are not the same person. Facial recognition algorithms can be affected by image quality, lighting, age differences, and facial expressions."]}],["$","li",null,{"children":[["$","strong",null,{"children":"False Negatives:"}]," The facial search engine may fail to identify matches that exist in public databases due to image resolution, angle variations, or incomplete indexing."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Algorithm Limitations:"}]," AI facial recognition is probabilistic, not deterministic. Confidence scores indicate likelihood, not certainty."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Database Coverage:"}]," FaceSeek searches publicly indexed web data. Images not indexed by search engines (Google, Bing, Yandex) will not appear in results."]}]]}]]}],["$","section",null,{"className":"space-y-4","children":[["$","h2",null,{"className":"text-xl font-black","children":"2. NOT A SUBSTITUTE FOR PROFESSIONAL VERIFICATION"}],["$","p",null,{"children":"FaceSeek is an investigative assist tool for facial intelligence research. It is NOT:"}],["$","ul",null,{"className":"list-disc pl-6 space-y-2 text-zinc-500","children":[["$","li",null,{"children":[["$","strong",null,{"children":"Legal Evidence:"}]," Facial search results are not admissible as standalone legal proof without independent verification."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Law Enforcement Tool:"}]," FaceSeek is not affiliated with any law enforcement agency and does not access restricted databases."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Identity Verification System:"}]," Our facial recognition search should not be used for KYC (Know Your Customer), employment screening, or official identity verification without additional verification methods."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Medical or Forensic Analysis:"}]," FaceSeek does not provide medical, forensic, or expert witness services."]}]]}]]}],["$","section",null,{"className":"space-y-4","children":[["$","h2",null,{"className":"text-xl font-black","children":"3. LOCATION INTELLIGENCE (PREDICTIVE) LIMITATIONS"}],["$","p",null,{"children":"FaceSeek Location Intelligence generates predictive location estimates by analyzing environmental cues in an image (architecture, vegetation, climate traces, terrain, signage presence, and urban density). This feature does not provide certainty and must not be treated as verified geolocation."}],"$L4","$L5"]}],"$L6","$L7","$L8","$L9"]}]}]}],["$La"],"$Lb"]}],"loading":null,"isPartial":false}
4:["$","ul",null,{"className":"list-disc pl-6 space-y-2 text-zinc-500","children":[["$","li",null,{"children":[["$","strong",null,{"children":"Predictions, not facts:"}]," Results may be incomplete, wrong, or misleading due to image quality, framing, indoor scenes, staged scenes, or AI-generated content."]}],["$","li",null,{"children":[["$","strong",null,{"children":"No user-upload image storage:"}]," We do not store uploaded images for this feature; processing is performed only to fulfill your request."]}],["$","li",null,{"children":[["$","strong",null,{"children":"User consent required:"}]," Analysis cannot be started unless you explicitly accept the required consent statement in the interface."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Liability:"}]," You are solely responsible for verifying outcomes and for any actions taken based on the results."]}]]}]
5:["$","div",null,{"className":"bg-amber-500/10 border border-amber-500/20 rounded-2xl p-5","children":["$","p",null,{"className":"text-[10px] font-bold uppercase tracking-widest leading-relaxed text-amber-200","children":[["$","strong",null,{"children":"MANDATORY NOTICE:"}]," Bu sonuçlar yapay zekâ tarafından üretilmiş tahminlerdir. Kesinlik içermez. Tüm hukuki ve fiili sorumluluk kullanıcıya aittir."]}]}]
6:["$","section",null,{"className":"space-y-4","children":[["$","h2",null,{"className":"text-xl font-black","children":"4. VISUAL SIMILARITY & LOCATION (WEB MATCHING) LIMITATIONS"}],["$","p",null,{"children":"FaceSeek Visual Similarity & Location combines mathematical similarity signals, optional EXIF GPS extraction, and third-party web match providers to produce a location estimate. Key limitations:"}],["$","ul",null,{"className":"list-disc pl-6 space-y-2 text-zinc-500","children":[["$","li",null,{"children":[["$","strong",null,{"children":"No “global coverage” guarantee:"}]," It is not possible to guarantee matching against “all indexed images on the internet.” Results depend on third-party provider coverage, availability, and rate limits."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Provider variability:"}]," Reverse-image availability and quality may differ across providers and may change without notice. Fallback mechanisms reduce failures but do not eliminate them."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Location extraction uncertainty:"}]," If EXIF GPS is missing, web pages may not include reliable geo metadata. Even when present, metadata can be outdated or incorrect."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Transparency:"}]," The report may include which sources contributed to the final location (e.g., EXIF, meta-tags, JSON-LD, geocoding). Absence of sources reduces confidence."]}]]}],["$","div",null,{"className":"bg-white/5 border border-white/10 rounded-2xl p-5","children":["$","p",null,{"className":"text-[10px] font-bold uppercase tracking-widest leading-relaxed text-zinc-300","children":[["$","strong",null,{"children":"TRANSPARENT NOTICE:"}]," If a minimum coverage or accuracy target cannot be guaranteed for your case, you will see that limitation reflected in the report and our public metrics."]}]}]]}]
7:["$","section",null,{"className":"space-y-4","children":[["$","h2",null,{"className":"text-xl font-black","children":"5. USER RESPONSIBILITY & ETHICAL USE"}],["$","p",null,{"children":"Users of our facial search engine are solely responsible for:"}],["$","ul",null,{"className":"list-disc pl-6 space-y-2 text-zinc-500","children":[["$","li",null,{"children":[["$","strong",null,{"children":"Verification:"}]," Independently verifying facial recognition results before taking action based on them."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Legal Compliance:"}]," Ensuring their use of facial search technology complies with local laws, GDPR, KVKK, and applicable privacy regulations."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Ethical Standards:"}]," Using image intelligence responsibly and not for harassment, stalking, discrimination, or unlawful surveillance."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Consequences:"}]," Any decisions, actions, or outcomes resulting from facial search results."]}]]}]]}]
8:["$","section",null,{"className":"space-y-4","children":[["$","h2",null,{"className":"text-xl font-black","children":"6. NO WARRANTIES OR GUARANTEES"}],["$","p",null,{"children":"FaceSeek provides facial recognition search services \"AS IS\" without warranties of any kind, including:"}],["$","ul",null,{"className":"list-disc pl-6 space-y-2 text-zinc-500","children":[["$","li",null,{"children":"No guarantee of accuracy, completeness, or reliability of facial search results."}],["$","li",null,{"children":"No warranty that the facial search engine will be error-free, uninterrupted, or secure."}],["$","li",null,{"children":"No guarantee that image intelligence data will be current, up-to-date, or comprehensive."}],["$","li",null,{"children":"No warranty regarding third-party data sources (Google, Bing, Yandex, OSINT databases)."}]]}]]}]
9:["$","section",null,{"className":"bg-primary/5 p-6 rounded-2xl border border-primary/10","children":["$","p",null,{"className":"text-[10px] font-bold uppercase tracking-widest leading-relaxed","children":[["$","strong",null,{"children":"CRITICAL NOTICE:"}]," FaceSeek is a technology platform, not a verification authority. Always conduct independent verification before making decisions based on facial recognition search results. Misuse of facial search technology may violate privacy laws and result in legal consequences."]}]}]
