{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/[locale]/layout,_N_T_/[locale]/location-intelligence/layout,_N_T_/[locale]/location-intelligence/page,_N_T_/en/location-intelligence"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/$d$locale/location-intelligence/__PAGE__",
    "/$d$locale/location-intelligence",
    "/$d$locale",
    "/_index",
    "/_head"
  ]
}