{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/[locale]/layout,_N_T_/[locale]/support/layout,_N_T_/[locale]/support/page,_N_T_/en/support"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/$d$locale/support/__PAGE__",
    "/$d$locale/support",
    "/$d$locale",
    "/_index",
    "/_head"
  ]
}