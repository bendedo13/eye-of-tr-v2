{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/[locale]/layout,_N_T_/[locale]/profile/layout,_N_T_/[locale]/profile/page,_N_T_/en/profile"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/$d$locale/profile/__PAGE__",
    "/$d$locale/profile",
    "/$d$locale",
    "/_index",
    "/_head"
  ]
}